{
  "$defs": {
    "axis": {
      "additionalProperties": false,
      "properties": {
        "axis_name": {
          "pattern": "^[a-z][a-z0-9_]{1,63}$",
          "type": "string"
        },
        "values": {
          "items": {
            "type": [
              "string",
              "integer"
            ]
          },
          "maxItems": 5,
          "minItems": 4,
          "type": "array",
          "uniqueItems": true
        }
      },
      "required": [
        "axis_name",
        "values"
      ],
      "type": "object"
    },
    "family": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "lifecycle_state": {
                "const": "integrated"
              }
            },
            "required": [
              "lifecycle_state"
            ]
          },
          "then": {
            "properties": {
              "integrated_task_set_sha256": {
                "$ref": "#/$defs/sha256"
              }
            }
          },
          "else": {
            "properties": {
              "integrated_task_set_sha256": {
                "type": "null"
              }
            }
          }
        }
      ],
      "properties": {
        "allowed_tools": {
          "items": {
            "pattern": "^[a-z0-9][a-z0-9._+-]{0,63}$",
            "type": "string"
          },
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        },
        "capability_tags": {
          "items": {
            "pattern": "^[a-z0-9][a-z0-9-]{2,95}$",
            "type": "string"
          },
          "minItems": 3,
          "type": "array",
          "uniqueItems": true
        },
        "family_id": {
          "pattern": "^[a-z0-9][a-z0-9-]{2,95}$",
          "type": "string"
        },
        "family_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "filesystem_schema": {
          "pattern": "^[a-z0-9][a-z0-9-]{2,95}$",
          "type": "string"
        },
        "integrated_task_set_sha256": {
          "oneOf": [
            {
              "$ref": "#/$defs/sha256"
            },
            {
              "type": "null"
            }
          ]
        },
        "lifecycle_state": {
          "enum": [
            "integrated",
            "planned"
          ]
        },
        "output_contract": {
          "pattern": "^[a-z0-9][a-z0-9-]{2,95}$",
          "type": "string"
        },
        "parameter_axes": {
          "items": {
            "$ref": "#/$defs/axis"
          },
          "maxItems": 2,
          "minItems": 2,
          "type": "array"
        },
        "solution_track": {
          "enum": [
            "bash-native",
            "python-permitted"
          ]
        },
        "task_count": {
          "const": 20
        }
      },
      "required": [
        "family_id",
        "lifecycle_state",
        "task_count",
        "parameter_axes",
        "solution_track",
        "allowed_tools",
        "filesystem_schema",
        "output_contract",
        "capability_tags",
        "integrated_task_set_sha256",
        "family_sha256"
      ],
      "type": "object"
    },
    "sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "source": {
      "additionalProperties": false,
      "properties": {
        "added_task_count": {
          "minimum": 1,
          "type": "integer"
        },
        "cumulative_suite_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "cumulative_task_count": {
          "maximum": 380,
          "minimum": 1,
          "type": "integer"
        },
        "registry_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "tranche_id": {
          "pattern": "^[a-z0-9][a-z0-9-]{2,95}$",
          "type": "string"
        }
      },
      "required": [
        "tranche_id",
        "added_task_count",
        "cumulative_task_count",
        "registry_sha256",
        "cumulative_suite_sha256"
      ],
      "type": "object"
    }
  },
