    "suite_id",
    "family_count",
    "tasks_per_family",
    "total_task_count",
    "integrated_family_count",
    "integrated_task_count",
    "planned_family_count",
    "planned_task_count",
    "canonical_family_order",
    "predecessor",
    "source_registry_commitments",
    "families",
    "hardlink_discrimination_sha256",
    "coverage_sha256",
    "public_method_development",
    "sealed",
    "scored",
