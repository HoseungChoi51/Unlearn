{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/HoseungChoi51/Unlearn/raw/main/experiment-manifest.schema.json",
  "title": "Capability-Budgeted Dense Specialization Experiment Manifest",
  "description": "Measured accounting and export identity for one completed experiment run, cryptographically bound to a separate prospective run specification.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "experiment_id",
    "run_id",
    "stage",
    "run_spec_schema_version",
    "run_spec_sha256",
    "created_at",
    "git_revision",
    "model",
    "tokenizer",
    "data",
    "execution",
    "capability_mixture",
    "teacher",
    "operator",
    "optimizer",
    "training_protocol",
    "seeds",
    "tokens",
    "flops",
    "checkpoint",
    "export"
  ],
  "properties": {
    "schema_version": { "const": "2.0.0" },
    "experiment_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{7,127}$"
    },
    "run_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{7,127}$"
    },
    "stage": { "enum": ["train", "compress"] },
    "run_spec_schema_version": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$",
      "maxLength": 32
    },
    "run_spec_sha256": { "$ref": "#/$defs/sha256" },
    "created_at": { "type": "string", "format": "date-time" },
    "git_revision": { "$ref": "#/$defs/sha1" },
    "model": { "$ref": "#/$defs/model" },
    "tokenizer": { "$ref": "#/$defs/tokenizer" },
    "data": { "$ref": "#/$defs/data" },
    "execution": { "$ref": "#/$defs/execution" },
    "capability_mixture": { "$ref": "#/$defs/capabilityMixture" },
    "teacher": { "$ref": "#/$defs/teacher" },
    "operator": { "$ref": "#/$defs/operator" },
    "optimizer": { "$ref": "#/$defs/optimizer" },
    "training_protocol": { "$ref": "#/$defs/trainingProtocol" },
    "seeds": { "$ref": "#/$defs/seeds" },
    "tokens": { "$ref": "#/$defs/tokens" },
    "flops": { "$ref": "#/$defs/flops" },
    "checkpoint": { "$ref": "#/$defs/checkpoint" },
    "export": { "$ref": "#/$defs/export" },
    "notes": { "type": "string", "maxLength": 4096 }
  },
  "$defs": {
    "sha1": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "nullableSha256": {
      "anyOf": [
        { "$ref": "#/$defs/sha256" },
        { "type": "null" }
      ]
    },
    "immutableRevision": {
      "type": "string",
      "pattern": "^[0-9a-f]{40,64}$"
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "revision",
        "inspection_report_sha256",
        "architecture",
        "physical_parameters"
      ],
      "properties": {
        "repository": { "type": "string", "minLength": 1, "maxLength": 256 },
        "revision": { "$ref": "#/$defs/immutableRevision" },
        "inspection_report_sha256": { "$ref": "#/$defs/sha256" },
        "architecture": { "const": "dense" },
        "physical_parameters": {
          "type": "integer",
          "minimum": 1,
          "maximum": 999999999
        }
      }
    },
    "tokenizer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "revision",
        "source_sha256",
        "derived_vocabulary_mapping_sha256",
        "vocabulary_size"
      ],
      "properties": {
        "repository": { "type": "string", "minLength": 1, "maxLength": 256 },
        "revision": { "$ref": "#/$defs/immutableRevision" },
        "source_sha256": { "$ref": "#/$defs/sha256" },
        "derived_vocabulary_mapping_sha256": { "$ref": "#/$defs/nullableSha256" },
        "vocabulary_size": { "type": "integer", "minimum": 1 }
      }
    },
    "split": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "sha256", "sealed", "role"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{1,63}$"
        },
        "sha256": { "$ref": "#/$defs/sha256" },
        "sealed": { "type": "boolean" },
        "role": {
          "enum": [
            "training",
            "operator_selection",
            "method_development",
            "shadow_validation",
            "sealed_test",
            "diagnostic"
          ]
        }
      }
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manifest_sha256",
        "semantic_graph_sha256",
        "fixtures_sha256",
        "splits"
      ],
      "properties": {
        "manifest_sha256": { "$ref": "#/$defs/sha256" },
        "semantic_graph_sha256": { "$ref": "#/$defs/sha256" },
        "fixtures_sha256": { "$ref": "#/$defs/sha256" },
        "splits": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "items": { "$ref": "#/$defs/split" }
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["container_image_digest", "verifier_revision", "verifier_sha256"],
      "properties": {
        "container_image_digest": {
          "type": "string",
          "pattern": "^(?:[^\\s@]+@)?sha256:[0-9a-f]{64}$"
        },
        "verifier_revision": { "$ref": "#/$defs/immutableRevision" },
        "verifier_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "capabilityEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "fraction", "data_sha256"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 128 },
        "fraction": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1
        },
        "data_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "capabilityMixture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target", "support"],
      "properties": {
        "target": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "items": { "$ref": "#/$defs/capabilityEntry" }
        },
        "support": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "items": { "$ref": "#/$defs/capabilityEntry" }
        }
      }
    },
    "teacher": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "repository",
        "revision",
        "verified_corpus_sha256",
        "generation_flops"
      ],
      "properties": {
        "enabled": { "type": "boolean" },
        "repository": { "type": ["string", "null"], "maxLength": 256 },
        "revision": {
          "anyOf": [
            { "$ref": "#/$defs/immutableRevision" },
            { "type": "null" }
          ]
        },
        "verified_corpus_sha256": { "$ref": "#/$defs/nullableSha256" },
        "generation_flops": { "type": "number", "minimum": 0 }
      }
    },
    "structuralIndexGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["component", "layer", "indices"],
      "properties": {
        "component": {
          "enum": [
            "residual_branch",
            "attention_head",
            "ffn_channel",
            "hidden_dimension",
            "embedding_token",
            "layer"
          ]
        },
        "layer": { "type": ["integer", "null"], "minimum": 0 },
        "indices": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "bitAllocation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["component", "layer", "bits"],
      "properties": {
        "component": { "type": "string", "minLength": 1, "maxLength": 128 },
        "layer": {
          "anyOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "null" }
          ]
        },
        "bits": { "type": "number", "exclusiveMinimum": 0, "maximum": 32 }
      }
    },
    "lowRankFactorization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tensor_name",
        "component",
        "layer",
        "input_dimension",
        "output_dimension",
        "rank"
      ],
      "properties": {
        "tensor_name": { "type": "string", "minLength": 1, "maxLength": 512 },
        "component": {
          "enum": [
            "attention_q_proj",
            "attention_k_proj",
            "attention_v_proj",
            "attention_o_proj",
            "ffn_gate_proj",
            "ffn_up_proj",
            "ffn_down_proj",
            "embedding",
            "lm_head",
            "other_dense"
          ]
        },
        "layer": {
          "anyOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "null" }
          ]
        },
        "input_dimension": { "type": "integer", "minimum": 1 },
        "output_dimension": { "type": "integer", "minimum": 1 },
        "rank": { "type": "integer", "minimum": 1 }
      }
    },
    "operator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mechanism",
        "family",
        "configuration_sha256",
        "dose",
        "selection_strategy",
        "selection_split",
        "structural_indices",
        "bit_allocation",
        "factorizations",
        "selection_manifest_sha256",
        "archived_weights_sha256"
      ],
      "properties": {
        "mechanism": {
          "enum": [
            "baseline",
            "recycle",
            "prune",
            "quantize",
            "factorize",
            "distill",
            "hybrid"
          ]
        },
        "family": { "type": "string", "minLength": 1, "maxLength": 128 },
        "configuration_sha256": { "$ref": "#/$defs/sha256" },
        "dose": {
          "anyOf": [
            { "type": "number", "minimum": 0 },
            { "type": "string", "minLength": 1, "maxLength": 128 },
            { "type": "null" }
          ]
        },
        "selection_strategy": {
          "enum": [
            "none",
            "random",
            "uniform",
            "task_agnostic",
            "target_aware"
          ]
        },
        "selection_split": {
          "anyOf": [
            { "type": "string", "minLength": 1, "maxLength": 64 },
            { "type": "null" }
          ]
        },
        "structural_indices": {
          "type": "array",
          "maxItems": 4096,
          "items": { "$ref": "#/$defs/structuralIndexGroup" }
        },
        "bit_allocation": {
          "type": "array",
          "maxItems": 4096,
          "items": { "$ref": "#/$defs/bitAllocation" }
        },
        "factorizations": {
          "type": "array",
          "maxItems": 4096,
          "items": { "$ref": "#/$defs/lowRankFactorization" }
        },
        "selection_manifest_sha256": { "$ref": "#/$defs/nullableSha256" },
        "archived_weights_sha256": { "$ref": "#/$defs/nullableSha256" }
      }
    },
    "parameterGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "role", "learning_rate", "weight_decay"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 128 },
        "role": { "enum": ["backbone", "side_branch", "all_trainable"] },
        "learning_rate": { "type": "number", "exclusiveMinimum": 0 },
        "weight_decay": { "type": "number", "minimum": 0 }
      }
    },
    "optimizer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "name",
        "parameter_groups",
        "betas",
        "epsilon",
        "gradient_clip",
        "warmup_fraction",
        "schedule",
        "total_steps"
      ],
      "properties": {
        "enabled": { "type": "boolean" },
        "name": {
          "anyOf": [
            { "type": "string", "minLength": 1, "maxLength": 64 },
            { "type": "null" }
          ]
        },
        "parameter_groups": {
          "type": "array",
          "maxItems": 64,
          "items": { "$ref": "#/$defs/parameterGroup" }
        },
        "betas": {
          "type": "array",
          "maxItems": 2,
          "items": { "type": "number", "minimum": 0, "exclusiveMaximum": 1 }
        },
        "epsilon": {
          "anyOf": [
            { "type": "number", "exclusiveMinimum": 0 },
            { "type": "null" }
          ]
        },
        "gradient_clip": {
          "anyOf": [
            { "type": "number", "exclusiveMinimum": 0 },
            { "type": "null" }
          ]
        },
        "warmup_fraction": {
          "anyOf": [
            { "type": "number", "minimum": 0, "maximum": 1 },
            { "type": "null" }
          ]
        },
        "schedule": {
          "anyOf": [
            { "type": "string", "minLength": 1, "maxLength": 64 },
            { "type": "null" }
          ]
        },
        "total_steps": { "type": "integer", "minimum": 0 }
      }
    },
    "packing": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "strategy",
        "minimum_sequence_length",
        "maximum_sequence_length"
      ],
      "properties": {
        "enabled": { "type": "boolean" },
        "strategy": {
          "enum": ["greedy", "first_fit_decreasing", "none"]
        },
        "minimum_sequence_length": {
          "anyOf": [
            { "type": "integer", "minimum": 1 },
            { "type": "null" }
          ]
        },
        "maximum_sequence_length": {
          "anyOf": [
            { "type": "integer", "minimum": 1 },
            { "type": "null" }
          ]
        }
      }
    },
    "loss": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "objective",
        "label_scope",
        "target_weight",
        "support_weight",
        "kl_weight",
        "anchor_model_sha256"
      ],
      "properties": {
        "objective": {
          "enum": [
            "causal_cross_entropy",
            "causal_cross_entropy_with_kl",
            "none"
          ]
        },
        "label_scope": {
          "enum": [
            "all_non_padding_tokens",
            "assistant_response_tokens",
            "none"
          ]
        },
        "target_weight": { "type": "number", "minimum": 0 },
        "support_weight": { "type": "number", "minimum": 0 },
        "kl_weight": { "type": "number", "minimum": 0 },
        "anchor_model_sha256": { "$ref": "#/$defs/nullableSha256" }
      }
    },
    "freezing": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "trainable_parameters_sha256",
        "schedule_sha256"
      ],
      "properties": {
        "mode": { "enum": ["full_model", "side_only", "phased", "none"] },
        "trainable_parameters_sha256": { "$ref": "#/$defs/nullableSha256" },
        "schedule_sha256": { "$ref": "#/$defs/nullableSha256" }
      }
    },
    "trainingProtocol": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "training_dtype",
        "optimizer_state_dtype",
        "microbatch_size",
        "gradient_accumulation_steps",
        "data_parallel_world_size",
        "effective_batch_size",
        "attention_backend",
        "gradient_checkpointing",
        "deterministic_algorithms",
        "packing",
        "loss",
        "freezing"
      ],
      "properties": {
        "training_dtype": {
          "anyOf": [
            { "enum": ["bf16", "fp16", "fp32"] },
            { "type": "null" }
          ]
        },
        "optimizer_state_dtype": {
          "anyOf": [
            { "enum": ["bf16", "fp16", "fp32"] },
            { "type": "null" }
          ]
        },
        "microbatch_size": { "type": "integer", "minimum": 0 },
        "gradient_accumulation_steps": { "type": "integer", "minimum": 0 },
        "data_parallel_world_size": { "type": "integer", "minimum": 0 },
        "effective_batch_size": { "type": "integer", "minimum": 0 },
        "attention_backend": {
          "anyOf": [
            { "enum": ["sdpa", "flash_attention_2", "eager"] },
            { "type": "null" }
          ]
        },
        "gradient_checkpointing": { "type": "boolean" },
        "deterministic_algorithms": { "type": "boolean" },
        "packing": { "$ref": "#/$defs/packing" },
        "loss": { "$ref": "#/$defs/loss" },
        "freezing": { "$ref": "#/$defs/freezing" }
      }
    },
    "seeds": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model_initialization",
        "data_order",
        "training",
        "operator_selection",
        "evaluation"
      ],
      "properties": {
        "model_initialization": { "type": "integer", "minimum": 0 },
        "data_order": { "type": "integer", "minimum": 0 },
        "training": { "type": "integer", "minimum": 0 },
        "operator_selection": { "type": "integer", "minimum": 0 },
        "evaluation": { "type": "integer", "minimum": 0 }
      }
    },
    "tokens": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "optimizer_visible",
        "target",
        "replay",
        "teacher_derived",
        "selection_visible"
      ],
      "properties": {
        "optimizer_visible": { "type": "integer", "minimum": 0 },
        "target": { "type": "integer", "minimum": 0 },
        "replay": { "type": "integer", "minimum": 0 },
        "teacher_derived": { "type": "integer", "minimum": 0 },
        "selection_visible": { "type": "integer", "minimum": 0 }
      }
    },
    "flops": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selection",
        "teacher_generation",
        "training",
        "compression",
        "export",
        "total"
      ],
      "properties": {
        "selection": { "type": "number", "minimum": 0 },
        "teacher_generation": { "type": "number", "minimum": 0 },
        "training": { "type": "number", "minimum": 0 },
        "compression": { "type": "number", "minimum": 0 },
        "export": { "type": "number", "minimum": 0 },
        "total": { "type": "number", "minimum": 0 }
      }
    },
    "checkpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["selection_split", "metric", "mode", "tie_breakers", "rule"],
      "properties": {
        "selection_split": { "type": "string", "minLength": 1, "maxLength": 64 },
        "metric": { "type": "string", "minLength": 1, "maxLength": 128 },
        "mode": { "enum": ["min", "max"] },
        "tie_breakers": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 128 },
          "maxItems": 16
        },
        "rule": { "type": "string", "minLength": 1, "maxLength": 2048 }
      }
    },
    "export": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "architecture",
        "format",
        "runtime_compatibility",
        "physical_parameters",
        "active_parameters",
        "nonzero_parameters",
        "average_weight_bits",
        "weight_bytes",
        "bundle_bytes",
        "tokenizer_included",
        "artifact_sha256",
        "bundle_sha256",
        "tokenizer_sha256",
        "inspection_report_sha256"
      ],
      "properties": {
        "architecture": { "const": "dense" },
        "format": { "enum": ["safetensors", "gguf", "onnx", "other"] },
        "runtime_compatibility": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "items": { "type": "string", "minLength": 1, "maxLength": 128 }
        },
        "physical_parameters": {
          "type": "integer",
          "minimum": 1,
          "maximum": 999999999
        },
        "active_parameters": {
          "type": "integer",
          "minimum": 1,
          "maximum": 999999999
        },
        "nonzero_parameters": {
          "type": "integer",
          "minimum": 0,
          "maximum": 999999999
        },
        "average_weight_bits": { "type": "number", "exclusiveMinimum": 0, "maximum": 32 },
        "weight_bytes": { "type": "integer", "minimum": 1 },
        "bundle_bytes": { "type": "integer", "minimum": 1 },
        "tokenizer_included": { "const": true },
        "artifact_sha256": { "$ref": "#/$defs/sha256" },
        "bundle_sha256": { "$ref": "#/$defs/sha256" },
        "tokenizer_sha256": { "$ref": "#/$defs/sha256" },
        "inspection_report_sha256": {
          "$ref": "#/$defs/sha256",
          "description": "Canonical digest of a fresh inspection report produced from the completed exported artifact."
        }
      }
    }
  }
}
