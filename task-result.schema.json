{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/HoseungChoi51/Unlearn/raw/main/task-result.schema.json",
  "title": "Capability-Budgeted Dense Specialization Task Result",
  "description": "One content-safe terminal-task outcome. Prompt and generated program text are represented by identifiers and hashes, not embedded text.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "evaluation_id",
    "evaluation_spec_sha256",
    "run_id",
    "benchmark_id",
    "prompt_id",
    "task_record_sha256",
    "fixture_ids_sha256",
    "ordered_fixture_ids_sha256",
    "mode",
    "split_id",
    "split_role",
    "sealed",
    "attempt",
    "prior_attempt_terminal_statuses",
    "prior_attempt_result_sha256s",
    "action_limit",
    "prompt_tokens",
    "generated_tokens",
    "generated_text_sha256",
    "generated_text_bytes",
    "extraction",
    "syntax",
    "syntax_duration_ms",
    "tool_policy",
    "infrastructure_error",
    "fixture_outcomes",
    "resource_use",
    "action_trace",
    "terminal_status"
  ],
  "properties": {
    "schema_version": { "const": "3.0.0" },
    "evaluation_id": { "$ref": "#/$defs/identifier" },
    "evaluation_spec_sha256": { "$ref": "#/$defs/sha256" },
    "run_id": { "$ref": "#/$defs/identifier" },
    "benchmark_id": { "$ref": "#/$defs/identifier" },
    "prompt_id": { "$ref": "#/$defs/opaqueTaskIdentifier" },
    "task_record_sha256": { "$ref": "#/$defs/sha256" },
    "fixture_ids_sha256": { "$ref": "#/$defs/sha256" },
    "ordered_fixture_ids_sha256": { "$ref": "#/$defs/sha256" },
    "mode": { "enum": ["static", "interactive"] },
    "split_id": { "$ref": "#/$defs/identifier" },
    "split_role": {
      "enum": [
        "method_development",
        "shadow_validation",
        "sealed_id",
        "sealed_ood",
        "independent_benchmark"
      ]
    },
    "sealed": { "type": "boolean" },
    "attempt": { "type": "integer", "minimum": 1, "maximum": 3 },
    "prior_attempt_terminal_statuses": {
      "type": "array",
      "maxItems": 2,
      "items": { "$ref": "#/$defs/terminalStatus" }
    },
    "prior_attempt_result_sha256s": {
      "type": "array",
      "maxItems": 2,
      "items": { "$ref": "#/$defs/sha256" }
    },
    "action_limit": { "type": "integer", "minimum": 0, "maximum": 8 },
    "prompt_tokens": { "type": "integer", "minimum": 0 },
    "generated_tokens": { "type": "integer", "minimum": 0 },
    "generated_text_sha256": { "$ref": "#/$defs/sha256" },
    "generated_text_bytes": { "type": "integer", "minimum": 0 },
    "extraction": { "$ref": "#/$defs/extraction" },
    "syntax": { "$ref": "#/$defs/syntax" },
    "syntax_duration_ms": { "$ref": "#/$defs/nullableNonnegativeNumber" },
    "tool_policy": { "$ref": "#/$defs/toolPolicy" },
    "infrastructure_error": {
      "anyOf": [
        { "$ref": "#/$defs/infrastructureError" },
        { "type": "null" }
      ]
    },
    "fixture_outcomes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": { "$ref": "#/$defs/fixtureOutcome" }
    },
    "resource_use": { "$ref": "#/$defs/resourceUse" },
    "action_trace": {
      "type": "array",
      "maxItems": 8,
      "items": { "$ref": "#/$defs/actionTraceEntry" }
    },
    "terminal_status": { "$ref": "#/$defs/terminalStatus" }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "nullableSha256": {
      "anyOf": [
        { "$ref": "#/$defs/sha256" },
        { "type": "null" }
      ]
    },
    "nullableInteger": {
      "type": ["integer", "null"],
      "minimum": -2147483648,
      "maximum": 2147483647
    },
    "nullableNumber": {
      "type": ["number", "null"]
    },
    "nullableNonnegativeNumber": {
      "anyOf": [
        { "type": "number", "minimum": 0 },
        { "type": "null" }
      ]
    },
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 192,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]*$"
    },
    "opaqueTaskIdentifier": {
      "type": "string",
      "pattern": "^task-[0-9a-f]{64}$"
    },
    "opaqueFixtureIdentifier": {
      "type": "string",
      "pattern": "^fixture-[0-9a-f]{64}$"
    },
    "terminalStatus": {
      "enum": [
        "passed",
        "extraction_failure",
        "truncation",
        "syntax_failure",
        "syntax_check_failure",
        "disallowed_tool",
        "tool_policy_check_failure",
        "timeout",
        "runtime_failure",
        "functional_failure",
        "resource_limit",
        "verifier_failure",
        "action_limit",
        "internal_error"
      ]
    },
    "detailCode": {
      "enum": [
        "empty_response",
        "malformed_fence",
        "multiple_fences",
        "surrounding_prose",
        "unsupported_language",
        "nul_byte",
        "empty_program",
        "response_byte_limit",
        "token_limit",
        null
      ]
    },
    "extraction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "language",
        "code_sha256",
        "fenced",
        "response_bytes",
        "code_bytes",
        "detail_code"
      ],
      "properties": {
        "status": {
          "enum": ["ok", "extraction_failure", "truncation"]
        },
        "language": {
          "type": ["string", "null"],
          "enum": ["bash", "python", null]
        },
        "code_sha256": { "$ref": "#/$defs/nullableSha256" },
        "fenced": { "type": ["boolean", "null"] },
        "response_bytes": { "type": "integer", "minimum": 0 },
        "code_bytes": { "type": "integer", "minimum": 0 },
        "detail_code": { "$ref": "#/$defs/detailCode" }
      }
    },
    "syntax": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "return_code", "diagnostic_sha256"],
      "properties": {
        "status": {
          "enum": ["not_run", "ok", "syntax_failure", "check_failure"]
        },
        "return_code": { "$ref": "#/$defs/nullableInteger" },
        "diagnostic_sha256": { "$ref": "#/$defs/nullableSha256" }
      }
    },
    "toolPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "policy_sha256",
        "observed_tools",
        "disallowed_tools",
        "diagnostic_sha256"
      ],
      "properties": {
        "status": {
          "enum": ["not_run", "allowed", "disallowed_tool", "check_failure"]
        },
        "policy_sha256": { "$ref": "#/$defs/sha256" },
        "observed_tools": {
          "type": "array",
          "maxItems": 256,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._+-]{0,127}$"
          }
        },
        "disallowed_tools": {
          "type": "array",
          "maxItems": 256,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._+-]{0,127}$"
          }
        },
        "diagnostic_sha256": { "$ref": "#/$defs/nullableSha256" }
      }
    },
    "infrastructureError": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage", "diagnostic_sha256"],
      "properties": {
        "stage": {
          "enum": [
            "container_setup",
            "fixture_setup",
            "action_loop",
            "result_collection"
          ]
        },
        "diagnostic_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "fixtureOutcome": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fixture_id",
        "status",
        "exit_code",
        "stdout_sha256",
        "stderr_sha256",
        "stdout_bytes",
        "stderr_bytes",
        "wall_time_ms",
        "cpu_time_ms",
        "peak_rss_bytes",
        "peak_workspace_bytes",
        "peak_pids",
        "peak_open_files",
        "verifier_result_sha256"
      ],
      "properties": {
        "fixture_id": { "$ref": "#/$defs/opaqueFixtureIdentifier" },
        "status": {
          "enum": [
            "not_run",
            "passed",
            "timeout",
            "runtime_failure",
            "functional_failure",
            "resource_limit",
            "verifier_failure"
          ]
        },
        "exit_code": { "$ref": "#/$defs/nullableInteger" },
        "stdout_sha256": { "$ref": "#/$defs/nullableSha256" },
        "stderr_sha256": { "$ref": "#/$defs/nullableSha256" },
        "stdout_bytes": { "type": "integer", "minimum": 0 },
        "stderr_bytes": { "type": "integer", "minimum": 0 },
        "wall_time_ms": {
          "$ref": "#/$defs/nullableNonnegativeNumber",
          "description": "Candidate sandbox wall time for this fixture, excluding verifier time."
        },
        "cpu_time_ms": { "$ref": "#/$defs/nullableNonnegativeNumber" },
        "peak_rss_bytes": { "type": ["integer", "null"], "minimum": 1 },
        "peak_workspace_bytes": { "type": ["integer", "null"], "minimum": 0 },
        "peak_pids": { "type": ["integer", "null"], "minimum": 1 },
        "peak_open_files": { "type": ["integer", "null"], "minimum": 1 },
        "verifier_result_sha256": { "$ref": "#/$defs/nullableSha256" }
      }
    },
    "resourceUse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "container_started",
        "scope",
        "measurement_method",
        "measurement_report_sha256",
        "wall_time_ms",
        "cpu_time_ms",
        "peak_rss_bytes",
        "stdout_bytes",
        "stderr_bytes",
        "peak_workspace_bytes",
        "peak_pids",
        "peak_open_files",
        "timed_out"
      ],
      "properties": {
        "container_started": { "type": "boolean" },
        "scope": { "const": "maximum_over_fixture_and_action_invocations" },
        "measurement_method": { "const": "cgroup-v2-procfs-rusage-v1" },
        "measurement_report_sha256": { "$ref": "#/$defs/nullableSha256" },
        "wall_time_ms": {
          "type": "number",
          "minimum": 0,
          "description": "Maximum wall time of any one executed fixture or accepted action, not a task-wide sum."
        },
        "cpu_time_ms": {
          "$ref": "#/$defs/nullableNonnegativeNumber",
          "description": "Maximum CPU time of any one executed fixture or accepted action."
        },
        "peak_rss_bytes": {
          "type": ["integer", "null"],
          "minimum": 1,
          "description": "Maximum peak RSS of any one executed fixture or accepted action."
        },
        "stdout_bytes": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum raw stdout bytes emitted by any one executed fixture or accepted action."
        },
        "stderr_bytes": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum raw stderr bytes emitted by any one executed fixture or accepted action."
        },
        "peak_workspace_bytes": { "type": ["integer", "null"], "minimum": 0 },
        "peak_pids": { "type": ["integer", "null"], "minimum": 1 },
        "peak_open_files": { "type": ["integer", "null"], "minimum": 1 },
        "timed_out": { "type": "boolean" }
      }
    },
    "actionTraceEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_index",
        "action_sha256",
        "status",
        "exit_code",
        "stdout_sha256",
        "stderr_sha256",
        "stdout_bytes",
        "stderr_bytes",
        "wall_time_ms",
        "cpu_time_ms",
        "peak_rss_bytes",
        "peak_workspace_bytes",
        "peak_pids",
        "peak_open_files",
        "observation_bytes"
      ],
      "properties": {
        "action_index": { "type": "integer", "minimum": 0, "maximum": 7 },
        "action_sha256": { "$ref": "#/$defs/sha256" },
        "status": {
          "enum": [
            "passed",
            "extraction_failure",
            "truncation",
            "syntax_failure",
            "syntax_check_failure",
            "disallowed_tool",
            "tool_policy_check_failure",
            "timeout",
            "runtime_failure",
            "resource_limit"
          ]
        },
        "exit_code": { "$ref": "#/$defs/nullableInteger" },
        "stdout_sha256": { "$ref": "#/$defs/nullableSha256" },
        "stderr_sha256": { "$ref": "#/$defs/nullableSha256" },
        "stdout_bytes": { "type": "integer", "minimum": 0 },
        "stderr_bytes": { "type": "integer", "minimum": 0 },
        "wall_time_ms": {
          "$ref": "#/$defs/nullableNonnegativeNumber",
          "description": "Candidate sandbox wall time for this accepted action."
        },
        "cpu_time_ms": { "$ref": "#/$defs/nullableNonnegativeNumber" },
        "peak_rss_bytes": { "type": ["integer", "null"], "minimum": 1 },
        "peak_workspace_bytes": { "type": ["integer", "null"], "minimum": 0 },
        "peak_pids": { "type": ["integer", "null"], "minimum": 1 },
        "peak_open_files": { "type": ["integer", "null"], "minimum": 1 },
        "observation_bytes": {
          "type": "integer",
          "minimum": 0,
          "description": "Raw bytes returned to the model as this action's observation."
        }
      }
    }
  }
}
